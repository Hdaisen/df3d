<Application x:Class="DF3D.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="http://www.hardcodet.net/taskbar"
             ShutdownMode="OnExplicitShutdown"
             Startup="OnStartup">
    <Application.Resources>
        <!-- System tray icon -->
        <tb:TaskbarIcon x:Key="TrayIcon"
                        ToolTipText="DF3D - 3D 晕动症缓解工具"
                        IconSource="/Resources/Assets/tray-icon.ico"
                        LeftClickCommand="{Binding ShowSettingsCommand}"
                        DoubleClickCommand="{Binding ShowSettingsCommand}">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="打开设置" Click="OnTrayShowSettings"/>
                    <Separator/>
                    <MenuItem x:Name="TrayMenuOverlay" Header="✅ 叠加层" Click="OnTrayToggleOverlay"/>
                    <MenuItem x:Name="TrayMenuCrosshair" Header="✅ 十字线" Click="OnTrayToggleCrosshair"/>
                    <Separator/>
                    <MenuItem Header="退出" Click="OnTrayExit"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Application.Resources>
</Application>
