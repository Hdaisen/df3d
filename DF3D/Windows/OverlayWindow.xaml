<Window x:Class="DF3D.Windows.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:DF3D.Controls"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize"
        WindowState="Maximized">

    <Grid>
        <controls:VignetteControl x:Name="Vignette" />
        <controls:CrosshairControl x:Name="Crosshair" />
    </Grid>
</Window>
