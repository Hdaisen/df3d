<Window x:Class="DF3D.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DF3D - 设置"
        Width="520" Height="620"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E"
        Foreground="#CDD6F4"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        FontSize="13">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#181825" CornerRadius="8" Padding="16,12" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="🛡️ DF3D" FontSize="20" FontWeight="Bold" Foreground="#CDD6F4"/>
                <TextBlock Text="3D 晕动症缓解工具" Foreground="#A6ADC8" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Tab control -->
        <TabControl x:Name="MainTabs" Grid.Row="1" Background="Transparent" BorderThickness="0">

            <!-- Overlay Tab -->
            <TabItem Header="  🎭 叠加层  ">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8">
                    <StackPanel>
                        <CheckBox x:Name="ChkOverlayVisible" Content="显示叠加层" Foreground="#CDD6F4"
                                  Margin="0,0,0,12" Checked="OnOverlaySettingChanged" Unchecked="OnOverlaySettingChanged"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="形状" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                            <ComboBox x:Name="CmbOverlayShape" Grid.Column="1"
                                      Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" Padding="8,6"
                                      SelectionChanged="OnOverlaySettingChanged"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="大小" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                            <ComboBox x:Name="CmbOverlaySize" Grid.Column="1"
                                      Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" Padding="8,6"
                                      SelectionChanged="OnOverlaySettingChanged"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="长度" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                            <ComboBox x:Name="CmbOverlayLength" Grid.Column="1"
                                      Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" Padding="8,6"
                                      SelectionChanged="OnOverlaySettingChanged"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="颜色" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                            <ComboBox x:Name="CmbOverlayColor" Grid.Column="1"
                                      Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" Padding="8,6"
                                      SelectionChanged="OnOverlaySettingChanged"/>
                        </Grid>

                        <Grid x:Name="PanelOverlayCustomColor" Margin="0,0,0,8" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="自定义色" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtOverlayCustomColor" Grid.Column="1"
                                     Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" Padding="6,4"
                                     Text="#000000" LostFocus="OnOverlaySettingChanged"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="不透明度" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                            <Slider x:Name="SliderOverlayOpacity" Grid.Column="1"
                                    Foreground="#89B4FA" Background="#313244"
                                    Minimum="0" Maximum="1" Value="0.7" TickFrequency="0.05"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="OnOverlayOpacityChanged"/>
                            <TextBlock x:Name="TxtOverlayOpacity" Grid.Column="2"
                                       Text="70%" Foreground="#A6ADC8"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="宽高比" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                            <ComboBox x:Name="CmbOverlayAspect" Grid.Column="1"
                                      Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" Padding="8,6"
                                      SelectionChanged="OnOverlaySettingChanged"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="显示模式" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                            <ComboBox x:Name="CmbOverlayDisplayMode" Grid.Column="1"
                                      Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" Padding="8,6"
                                      SelectionChanged="OnOverlaySettingChanged"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="分屏" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                            <ComboBox x:Name="CmbOverlaySplit" Grid.Column="1"
                                      Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" Padding="8,6"
                                      SelectionChanged="OnOverlaySettingChanged"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Crosshair Tab -->
            <TabItem Header="  ➕ 十字线  ">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8">
                    <StackPanel>
                        <CheckBox x:Name="ChkCrosshairVisible" Content="显示十字线" Foreground="#CDD6F4"
                                  Margin="0,0,0,12" Checked="OnCrosshairSettingChanged" Unchecked="OnCrosshairSettingChanged"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="形状" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                            <ComboBox x:Name="CmbCrossShape" Grid.Column="1"
                                      Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" Padding="8,6"
                                      SelectionChanged="OnCrosshairSettingChanged"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="大小" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                            <ComboBox x:Name="CmbCrossSize" Grid.Column="1"
                                      Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" Padding="8,6"
                                      SelectionChanged="OnCrosshairSettingChanged"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="粗细" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                            <Slider x:Name="SliderCrossThickness" Grid.Column="1"
                                    Foreground="#89B4FA" Background="#313244"
                                    Minimum="1" Maximum="8" Value="2" TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="OnCrosshairThicknessChanged"/>
                            <TextBlock x:Name="TxtCrossThickness" Grid.Column="2"
                                       Text="2" Foreground="#A6ADC8"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="颜色" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                            <ComboBox x:Name="CmbCrossColor" Grid.Column="1"
                                      Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" Padding="8,6"
                                      SelectionChanged="OnCrosshairSettingChanged"/>
                        </Grid>

                        <Grid x:Name="PanelCrossCustomColor" Margin="0,0,0,8" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="自定义色" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                            <TextBox x:Name="TxtCrossCustomColor" Grid.Column="1"
                                     Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" Padding="6,4"
                                     Text="#00FF00" LostFocus="OnCrosshairSettingChanged"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="不透明度" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                            <Slider x:Name="SliderCrossOpacity" Grid.Column="1"
                                    Foreground="#89B4FA" Background="#313244"
                                    Minimum="0" Maximum="1" Value="0.8" TickFrequency="0.05"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="OnCrosshairOpacityChanged"/>
                            <TextBlock x:Name="TxtCrossOpacity" Grid.Column="2"
                                       Text="80%" Foreground="#A6ADC8"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="X 偏移" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                            <Slider x:Name="SliderCrossX" Grid.Column="1"
                                    Foreground="#89B4FA" Background="#313244"
                                    Minimum="-200" Maximum="200" Value="0" TickFrequency="5"
                                    ValueChanged="OnCrosshairOffsetChanged"/>
                            <TextBlock x:Name="TxtCrossX" Grid.Column="2"
                                       Text="0" Foreground="#A6ADC8"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Y 偏移" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                            <Slider x:Name="SliderCrossY" Grid.Column="1"
                                    Foreground="#89B4FA" Background="#313244"
                                    Minimum="-200" Maximum="200" Value="0" TickFrequency="5"
                                    ValueChanged="OnCrosshairOffsetChanged"/>
                            <TextBlock x:Name="TxtCrossY" Grid.Column="2"
                                       Text="0" Foreground="#A6ADC8"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Hotkeys Tab -->
            <TabItem Header="  ⌨️ 热键  ">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8">
                    <StackPanel>
                        <TextBlock Text="以下热键在游戏内全局生效（无边框/窗口模式下）"
                                   Foreground="#A6ADC8" TextWrapping="Wrap" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="切换叠加层" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                            <Button x:Name="BtnHotkeyOverlay" Grid.Column="1"
                                    Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" Padding="12,6"
                                    Click="OnHotkeyButtonClick" Tag="Overlay" MinWidth="160"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="切换十字线" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                            <Button x:Name="BtnHotkeyCrosshair" Grid.Column="1"
                                    Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" Padding="12,6"
                                    Click="OnHotkeyButtonClick" Tag="Crosshair" MinWidth="160"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="切换分屏模式" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                            <Button x:Name="BtnHotkeySplit" Grid.Column="1"
                                    Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" Padding="12,6"
                                    Click="OnHotkeyButtonClick" Tag="Split" MinWidth="160"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="切换显示模式" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                            <Button x:Name="BtnHotkeyDisplay" Grid.Column="1"
                                    Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" Padding="12,6"
                                    Click="OnHotkeyButtonClick" Tag="Display" MinWidth="160"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="切换遮罩大小" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                            <Button x:Name="BtnHotkeySize" Grid.Column="1"
                                    Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" Padding="12,6"
                                    Click="OnHotkeyButtonClick" Tag="Size" MinWidth="160"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="切换预设" Foreground="#A6ADC8" VerticalAlignment="Center"/>
                            <Button x:Name="BtnHotkeyProfile" Grid.Column="1"
                                    Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" Padding="12,6"
                                    Click="OnHotkeyButtonClick" Tag="Profile" MinWidth="160"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Profiles Tab -->
            <TabItem Header="  📋 预设  ">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="CmbProfiles" Grid.Column="0"
                                      Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" Padding="8,6"
                                      SelectionChanged="OnProfileSelectionChanged"/>
                            <Button x:Name="BtnSaveProfile" Grid.Column="1" Content="保存当前"
                                    Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" Padding="12,6"
                                    Margin="8,0,0,0" Click="OnSaveProfileClick"/>
                            <Button x:Name="BtnDeleteProfile" Grid.Column="2" Content="删除"
                                    Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" Padding="12,6"
                                    Margin="4,0,0,0" Click="OnDeleteProfileClick"/>
                        </Grid>

                        <TextBlock Text="预设会保存当前叠加层和十字线的所有设置。切换预设时自动加载对应配置。"
                                   Foreground="#A6ADC8" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- General Tab -->
            <TabItem Header="  ⚙️ 通用  ">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8">
                    <StackPanel>
                        <CheckBox x:Name="ChkStartup" Content="开机自启动" Foreground="#CDD6F4"
                                  Margin="0,0,0,12" Checked="OnStartupChanged" Unchecked="OnStartupChanged"/>

                        <CheckBox x:Name="ChkShowOverlayOnStart" Content="启动时显示叠加层" Foreground="#CDD6F4"
                                  Margin="0,0,0,12" Checked="OnGeneralSettingChanged" Unchecked="OnGeneralSettingChanged"/>

                        <CheckBox x:Name="ChkShowCrosshairOnStart" Content="启动时显示十字线" Foreground="#CDD6F4"
                                  Margin="0,0,0,12" Checked="OnGeneralSettingChanged" Unchecked="OnGeneralSettingChanged"/>

                        <CheckBox x:Name="ChkMinimizeToTray" Content="关闭窗口时最小化到托盘" Foreground="#CDD6F4"
                                  Margin="0,0,0,12" Checked="OnGeneralSettingChanged" Unchecked="OnGeneralSettingChanged"/>

                        <Border Background="#313244" CornerRadius="8" Padding="12" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Text="关于" FontSize="14" FontWeight="SemiBold" Foreground="#89B4FA" Margin="0,0,0,4"/>
                                <TextBlock Text="DF3D - 3D 晕动症缓解工具" Foreground="#CDD6F4"/>
                                <TextBlock Text="通过边缘遮罩和固定参照点缓解 3D 游戏眩晕。" Foreground="#A6ADC8" Margin="0,4,0,0"/>
                                <TextBlock Foreground="#A6ADC8" Margin="0,4,0,0" TextWrapping="Wrap">
                                    原理：周边视觉中的运动会诱发晕动症，遮罩边缘可减少运动感知，十字线提供稳定参照。
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#181825" CornerRadius="6" Padding="12,8" Margin="0,12,0,0">
            <TextBlock x:Name="TxtStatus" Text="就绪" Foreground="#A6ADC8" FontSize="12"/>
        </Border>
    </Grid>
</Window>
