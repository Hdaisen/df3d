<Window x:Class="DF3D.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:DF3D.Models"
        Title="DF3D - 3D 晕动症缓解工具"
        Width="520" Height="620"
        MinWidth="480" MinHeight="580"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E"
        Foreground="#CDD6F4"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        FontSize="13">

    <Window.Resources>
        <!-- Color palette -->
        <SolidColorBrush x:Key="BgDark" Color="#181825"/>
        <SolidColorBrush x:Key="BgCard" Color="#313244"/>
        <SolidColorBrush x:Key="Accent" Color="#89B4FA"/>
        <SolidColorBrush x:Key="AccentHover" Color="#74C7EC"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#CDD6F4"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#A6ADC8"/>
        <SolidColorBrush x:Key="Border" Color="#45475A"/>
        <SolidColorBrush x:Key="Success" Color="#A6E3A1"/>
        <SolidColorBrush x:Key="Warning" Color="#F9E2AF"/>

        <!-- Button style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="{StaticResource BgDark}"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource Border}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox style -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <!-- Slider style -->
        <Style x:Key="DarkSlider" TargetType="Slider">
            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
        </Style>

        <!-- Section header style -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
            <Setter Property="Margin" Value="0,12,0,8"/>
        </Style>

        <!-- Label style -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource BgDark}" CornerRadius="8" Padding="16,12" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="🛡️ DF3D" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                <TextBlock Text="3D 晕动症缓解工具" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Tab control area -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0"
                    SelectedIndex="{Binding SelectedTab}">

            <!-- ====== Overlay Tab ====== -->
            <TabItem Header="  🎭 叠加层  ">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8">
                    <StackPanel>
                        <!-- Visibility toggle -->
                        <CheckBox x:Name="ChkOverlayVisible" Content="显示叠加层" Foreground="{StaticResource TextPrimary}"
                                  Margin="0,0,0,12" Checked="OnOverlaySettingChanged" Unchecked="OnOverlaySettingChanged"/>

                        <!-- Shape -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="形状" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="CmbOverlayShape" Grid.Column="1" Style="{StaticResource DarkComboBox}"
                                      SelectionChanged="OnOverlaySettingChanged"/>
                        </Grid>

                        <!-- Size -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="大小" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="CmbOverlaySize" Grid.Column="1" Style="{StaticResource DarkComboBox}"
                                      SelectionChanged="OnOverlaySettingChanged"/>
                        </Grid>

                        <!-- Length -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="长度" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="CmbOverlayLength" Grid.Column="1" Style="{StaticResource DarkComboBox}"
                                      SelectionChanged="OnOverlaySettingChanged"/>
                        </Grid>

                        <!-- Color -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="颜色" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="CmbOverlayColor" Grid.Column="1" Style="{StaticResource DarkComboBox}"
                                      SelectionChanged="OnOverlaySettingChanged"/>
                        </Grid>

                        <!-- Custom color hex (visible when Custom is selected) -->
                        <Grid x:Name="PanelOverlayCustomColor" Margin="0,0,0,8" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="自定义色" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TxtOverlayCustomColor" Grid.Column="1"
                                     Background="{StaticResource BgCard}" Foreground="{StaticResource TextPrimary}"
                                     BorderBrush="{StaticResource Border}" Padding="6,4"
                                     Text="#000000" LostFocus="OnOverlaySettingChanged"/>
                        </Grid>

                        <!-- Opacity -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="不透明度" Style="{StaticResource FieldLabel}"/>
                            <Slider x:Name="SliderOverlayOpacity" Grid.Column="1"
                                    Style="{StaticResource DarkSlider}"
                                    Minimum="0" Maximum="1" Value="0.7" TickFrequency="0.05"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="OnOverlayOpacityChanged"/>
                            <TextBlock x:Name="TxtOverlayOpacity" Grid.Column="2"
                                       Text="70%" Foreground="{StaticResource TextSecondary}"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- Aspect Ratio -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="宽高比" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="CmbOverlayAspect" Grid.Column="1" Style="{StaticResource DarkComboBox}"
                                      SelectionChanged="OnOverlaySettingChanged"/>
                        </Grid>

                        <!-- Display Mode -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="显示模式" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="CmbOverlayDisplayMode" Grid.Column="1" Style="{StaticResource DarkComboBox}"
                                      SelectionChanged="OnOverlaySettingChanged"/>
                        </Grid>

                        <!-- Split Screen -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="分屏" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="CmbOverlaySplit" Grid.Column="1" Style="{StaticResource DarkComboBox}"
                                      SelectionChanged="OnOverlaySettingChanged"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ====== Crosshair Tab ====== -->
            <TabItem Header="  ➕ 十字线  ">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8">
                    <StackPanel>
                        <CheckBox x:Name="ChkCrosshairVisible" Content="显示十字线" Foreground="{StaticResource TextPrimary}"
                                  Margin="0,0,0,12" Checked="OnCrosshairSettingChanged" Unchecked="OnCrosshairSettingChanged"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="形状" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="CmbCrossShape" Grid.Column="1" Style="{StaticResource DarkComboBox}"
                                      SelectionChanged="OnCrosshairSettingChanged"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="大小" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="CmbCrossSize" Grid.Column="1" Style="{StaticResource DarkComboBox}"
                                      SelectionChanged="OnCrosshairSettingChanged"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="粗细" Style="{StaticResource FieldLabel}"/>
                            <Slider x:Name="SliderCrossThickness" Grid.Column="1"
                                    Style="{StaticResource DarkSlider}"
                                    Minimum="1" Maximum="8" Value="2" TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="OnCrosshairThicknessChanged"/>
                            <TextBlock x:Name="TxtCrossThickness" Grid.Column="2"
                                       Text="2" Foreground="{StaticResource TextSecondary}"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="颜色" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="CmbCrossColor" Grid.Column="1" Style="{StaticResource DarkComboBox}"
                                      SelectionChanged="OnCrosshairSettingChanged"/>
                        </Grid>

                        <Grid x:Name="PanelCrossCustomColor" Margin="0,0,0,8" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="自定义色" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="TxtCrossCustomColor" Grid.Column="1"
                                     Background="{StaticResource BgCard}" Foreground="{StaticResource TextPrimary}"
                                     BorderBrush="{StaticResource Border}" Padding="6,4"
                                     Text="#00FF00" LostFocus="OnCrosshairSettingChanged"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="不透明度" Style="{StaticResource FieldLabel}"/>
                            <Slider x:Name="SliderCrossOpacity" Grid.Column="1"
                                    Style="{StaticResource DarkSlider}"
                                    Minimum="0" Maximum="1" Value="0.8" TickFrequency="0.05"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="OnCrosshairOpacityChanged"/>
                            <TextBlock x:Name="TxtCrossOpacity" Grid.Column="2"
                                       Text="80%" Foreground="{StaticResource TextSecondary}"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="X 偏移" Style="{StaticResource FieldLabel}"/>
                            <Slider x:Name="SliderCrossX" Grid.Column="1"
                                    Style="{StaticResource DarkSlider}"
                                    Minimum="-200" Maximum="200" Value="0" TickFrequency="5"
                                    ValueChanged="OnCrosshairOffsetChanged"/>
                            <TextBlock x:Name="TxtCrossX" Grid.Column="2"
                                       Text="0" Foreground="{StaticResource TextSecondary}"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Y 偏移" Style="{StaticResource FieldLabel}"/>
                            <Slider x:Name="SliderCrossY" Grid.Column="1"
                                    Style="{StaticResource DarkSlider}"
                                    Minimum="-200" Maximum="200" Value="0" TickFrequency="5"
                                    ValueChanged="OnCrosshairOffsetChanged"/>
                            <TextBlock x:Name="TxtCrossY" Grid.Column="2"
                                       Text="0" Foreground="{StaticResource TextSecondary}"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ====== Hotkeys Tab ====== -->
            <TabItem Header="  ⌨️ 热键  ">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8">
                    <StackPanel>
                        <TextBlock Text="以下热键在游戏内全局生效（无边框/窗口模式下）"
                                   Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,12"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="切换叠加层" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                            <Button x:Name="BtnHotkeyOverlay" Grid.Column="1" Style="{StaticResource SecondaryButton}"
                                    Click="OnHotkeyButtonClick" Tag="Overlay" MinWidth="160"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="切换十字线" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                            <Button x:Name="BtnHotkeyCrosshair" Grid.Column="1" Style="{StaticResource SecondaryButton}"
                                    Click="OnHotkeyButtonClick" Tag="Crosshair" MinWidth="160"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="切换分屏模式" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                            <Button x:Name="BtnHotkeySplit" Grid.Column="1" Style="{StaticResource SecondaryButton}"
                                    Click="OnHotkeyButtonClick" Tag="Split" MinWidth="160"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="切换显示模式" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                            <Button x:Name="BtnHotkeyDisplay" Grid.Column="1" Style="{StaticResource SecondaryButton}"
                                    Click="OnHotkeyButtonClick" Tag="Display" MinWidth="160"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="切换遮罩大小" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                            <Button x:Name="BtnHotkeySize" Grid.Column="1" Style="{StaticResource SecondaryButton}"
                                    Click="OnHotkeyButtonClick" Tag="Size" MinWidth="160"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="切换预设" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                            <Button x:Name="BtnHotkeyProfile" Grid.Column="1" Style="{StaticResource SecondaryButton}"
                                    Click="OnHotkeyButtonClick" Tag="Profile" MinWidth="160"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ====== Profiles Tab ====== -->
            <TabItem Header="  📋 预设  ">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="CmbProfiles" Grid.Column="0" Style="{StaticResource DarkComboBox}"
                                      SelectionChanged="OnProfileSelectionChanged"/>
                            <Button x:Name="BtnSaveProfile" Grid.Column="1" Content="保存当前"
                                    Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"
                                    Click="OnSaveProfileClick"/>
                            <Button x:Name="BtnDeleteProfile" Grid.Column="2" Content="删除"
                                    Style="{StaticResource SecondaryButton}" Margin="4,0,0,0"
                                    Click="OnDeleteProfileClick"/>
                        </Grid>

                        <TextBlock Text="预设会保存当前叠加层和十字线的所有设置。切换预设时自动加载对应配置。"
                                   Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ====== General Tab ====== -->
            <TabItem Header="  ⚙️ 通用  ">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,8">
                    <StackPanel>
                        <CheckBox x:Name="ChkStartup" Content="开机自启动" Foreground="{StaticResource TextPrimary}"
                                  Margin="0,0,0,12" Checked="OnStartupChanged" Unchecked="OnStartupChanged"/>

                        <CheckBox x:Name="ChkShowOverlayOnStart" Content="启动时显示叠加层" Foreground="{StaticResource TextPrimary}"
                                  Margin="0,0,0,12" Checked="OnGeneralSettingChanged" Unchecked="OnGeneralSettingChanged"/>

                        <CheckBox x:Name="ChkShowCrosshairOnStart" Content="启动时显示十字线" Foreground="{StaticResource TextPrimary}"
                                  Margin="0,0,0,12" Checked="OnGeneralSettingChanged" Unchecked="OnGeneralSettingChanged"/>

                        <CheckBox x:Name="ChkMinimizeToTray" Content="关闭窗口时最小化到托盘" Foreground="{StaticResource TextPrimary}"
                                  Margin="0,0,0,12" Checked="OnGeneralSettingChanged" Unchecked="OnGeneralSettingChanged"/>

                        <Border Background="{StaticResource BgCard}" CornerRadius="8" Padding="12" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Text="关于" Style="{StaticResource SectionHeader}" Margin="0,0,0,4"/>
                                <TextBlock Text="DF3D - 3D 晕动症缓解工具" Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="通过边缘遮罩和固定参照点缓解 3D 游戏眩晕。" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                                <TextBlock Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0">
                                    <Run Text="原理：周边视觉中的运动会诱发晕动症，"/>
                                    <Run Text="遮罩边缘可减少运动感知，十字线提供稳定参照。"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Footer status -->
        <Border Grid.Row="2" Background="{StaticResource BgDark}" CornerRadius="6" Padding="12,8" Margin="0,12,0,0">
            <TextBlock x:Name="TxtStatus" Text="就绪" Foreground="{StaticResource TextSecondary}" FontSize="12"/>
        </Border>
    </Grid>
</Window>
